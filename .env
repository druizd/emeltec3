# =============================================================================
# Emeltec Platform — .env raíz (TESTING / CONFORMIDAD)
# Single source of truth para todo el stack docker-compose.
# Valores reales test — NO usar en producción real (regenerar secrets antes).
# =============================================================================

# --- Docker Compose ---
COMPOSE_PROJECT_NAME=emeltec-platform

# --- Postgres / TimescaleDB (compartido) ---
POSTGRES_DB=telemetry_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin_password

# --- Puertos host ---
POSTGRES_HOST_PORT=5433
MAIN_API_HOST_PORT=3000
AUTH_API_HOST_PORT=3001
DGA_API_HOST_PORT=3002
FRONTEND_HOST_PORT=5173
METRICS_HOST_PORT=8081
CSVCONSUMER_HOST_PORT=50051

# --- DB tuning ---
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONN_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=10000
DB_SLOW_LOG_MS=500

# --- Logging / CORS ---
LOG_LEVEL=info
CORS_ORIGIN=*

# --- Auth (compartido main-api + auth-api) ---
JWT_SECRET=8f3a9c2e1b7d4f6a5e8c0b2d4f6a8c1e3b5d7f9a2c4e6b8d0f2a4c6e8b1d3f5a
INTERNAL_API_KEY=internal_test_key_a7b3c9d1e5f2g8h4i6j0

# --- Redis ---
REDIS_URL=redis://redis:6379
REDIS_KEY_PREFIX=emeltec:

# --- DGA ---
DGA_ENCRYPTION_KEY=d2445769d43145d20f9b3cb081112925bf4247edab5dc9de5774d4e2286a5ef3
DGA_API_URL=https://apimee.mop.gob.cl/api/v1/mediciones/subterraneas
DGA_RUT_EMPRESA=12345678-9

# --- Email (Resend) — sin key real, emails fallan silenciosamente ---
RESEND_API_KEY=re_WmUQHjEY_G9M3pR5oRfuAvFMYbhxoqvFH
RESEND_FROM=Emeltec - Panel Industrial <noreply@emeltec.cl>
FRONTEND_URL=https://cloud.emeltec.cl/login

# --- Rate limit ---
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX=5000

# --- Workers (1 réplica) ---
ENABLE_ALERTS_WORKER=true
ENABLE_DGA_WORKER=true
ENABLE_INGESTION_WORKER=true
ENABLE_SUBMISSION_WORKER=false
ENABLE_HEALTH_DIGEST_WORKER=false

# --- Worker tuning ---
ALERT_POLL_MS=60000
ALERT_TIMEZONE=America/Santiago
DGA_WORKER_POLL_MS=60000
DGA_WORKER_CATCHUP=false
INGESTION_CRON=* * * * *
SUBMISSION_CRON=*/5 * * * *
HEALTH_DIGEST_POLL_MS=60000
MONITOR_PRIMARY_EMAIL=druiz@emeltec.cl

# --- Azure Blob (documentos) — vacío = endpoint /api/documentos retorna 503 ---
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=bitacoradocumentos
AZURE_STORAGE_SAS_TTL_MIN=15
DOCUMENTOS_MAX_MB=25
