# Variables de entorno de ejemplo
# Copia este archivo como .env y completa con tus credenciales reales
# ⚠️ NUNCA subas el archivo .env real a GitHub

# Base de datos TimescaleDB
NODE_ENV=production
DB_HOST=localhost
DB_PORT=5433
DB_NAME=db_infra
DB_USER=admin_infra
DB_PASSWORD=TU_PASSWORD_AQUI
PORT=3000

# Auth compartido entre auth-api y main-api
JWT_SECRET=super_secret_dev_key_12345
INTERNAL_API_KEY=dev_internal_key

# Motor de correo (Resend)
RESEND_API_KEY=re_TU_API_KEY_AQUI
RESEND_FROM=Emeltec - Panel Industrial <noreply@emeltec.cl>
FRONTEND_URL=https://nuevacloud.emeltec.cl/login
