# Variables de entorno de ejemplo
# Copia este archivo como .env y completa con tus credenciales reales

NODE_ENV=production
PORT=3000
GRPC_PORT=50051
CORS_ORIGIN=*
LOG_LEVEL=info

# Base de datos TimescaleDB
DB_HOST=timescaledb
DB_PORT=5432
DB_NAME=telemetry_platform
DB_USER=postgres
DB_PASSWORD=CHANGE_ME
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONN_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=10000
DB_SLOW_LOG_MS=500

# Redis (opcional — si no se define, se deshabilita caché y rate-limit distribuido)
REDIS_URL=redis://redis:6379
REDIS_KEY_PREFIX=emeltec:

# Auth compartido entre auth-api y main-api
JWT_SECRET=CHANGE_ME_AL_MENOS_16_CARACTERES
INTERNAL_API_KEY=CHANGE_ME

# Motor de correo (Resend)
RESEND_API_KEY=re_TU_API_KEY_AQUI
RESEND_FROM=Emeltec - Panel Industrial <noreply@emeltec.cl>
FRONTEND_URL=https://cloud.emeltec.cl/login

# Rate limit global
# Margen amplio para evitar bloqueos durante recargas o errores repetidos.
# 0 lo deja deshabilitado por completo.
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX=5000

# Workers (en cluster, mantener encendido sólo en 1 réplica)
ENABLE_ALERTS_WORKER=true

# Health digest — monitor de transmisión + DGA.
# Event-driven al cruzar 3h/6h/12h sin reportar + resumen 07:00 y 16:00 hora Santiago.
# Por defecto desactivado; encender sólo en una réplica.
ENABLE_HEALTH_DIGEST_WORKER=false
MONITOR_PRIMARY_EMAIL=druiz@emeltec.cl
HEALTH_DIGEST_POLL_MS=60000

# DGA — clave de cifrado AES-256-GCM para clave_informante en BD.
# Generar UNA sola vez con: openssl rand -hex 32
# Si se cambia, las claves cifradas existentes dejan de descifrarse.
DGA_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS
