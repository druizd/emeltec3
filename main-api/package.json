{
  "name": "main-api",
  "version": "2.1.0",
  "description": "API principal de Emeltec — Node.js + TypeScript + TimescaleDB + Redis",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "echo 'No tests legacy; pendiente vitest+testcontainers contra /api/v2/*.'"
  },
  "keywords": [],
  "author": "Emeltec",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pg": "^8.20.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.2.0",
    "resend": "^4.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^24.12.4",
    "@types/pg": "^8.11.10",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.18.0"
  }
}
