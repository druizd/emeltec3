GRPC_ADDRESS=localhost:50051
TIMEOUT_SECONDS=10

# Rutas absolutas al directorio de datos (Windows)
INPUT_DIR=C:\ruta\csvprocessor\data\incoming_logs
RAW_BACKUP_DIR=C:\ruta\csvprocessor\data\raw_backup
FAILED_DIR=C:\ruta\csvprocessor\data\failed_logs

# Alertas a main-api (opcional)
MAIN_API_URL=
INTERNAL_API_KEY=

# Cola PLC en Linux y controlador MT-151 accesible desde Windows
SQLITE_PATH=C:\ruta\csvprocessor\data\local\telemetry_local.db
LINUX_DB_API_URL=http://IP_LINUX:3010
PLC_COMMAND_POLL_INTERVAL_SEC=5
PLC_DRY_RUN=true
PLC_DEVICE_ID_SERIAL=151.24.7.13
PLC_DEVICE_IP=192.168.1.100
PLC_DEVICE_PORT=502
PLC_DEVICE_UNIT_ID=1
PLC_DEVICE_TIMEOUT_SEC=5

NUM_WORKERS=8
WATCH_INTERVAL_MS=50
RETRY_INTERVAL_SEC=30
STATS_INTERVAL_SEC=10
