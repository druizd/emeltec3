
# =============================================================================
# Emeltec Platform — .env raíz (UNICO archivo para todo el stack)
# Copia como .env y completa valores reales. No commitear.
# =============================================================================

# --- Docker Compose ---
COMPOSE_PROJECT_NAME=emeltec-platform

# --- Postgres / TimescaleDB (compartido entre servicios) ---
POSTGRES_DB=telemetry_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Puertos expuestos en el host ---
POSTGRES_HOST_PORT=5433
MAIN_API_HOST_PORT=3000
LINUX_DB_API_HOST_PORT=3010
AUTH_API_HOST_PORT=3001
DGA_API_HOST_PORT=3002
FRONTEND_HOST_PORT=5173
METRICS_HOST_PORT=8081
CSVCONSUMER_HOST_PORT=50051
FTPCONSUMER_HOST_PORT=50061

# --- Windows csvprocessor / PLC bridge ---
# En Windows produccion normalmente:
# SQLITE_PATH=C:\Users\azureuser\Documents\csvprocessor\data\local\telemetry_local.db
SQLITE_PATH=data/local/telemetry_local.db
LOCAL_SYNC_INTERVAL_SEC=30
LINUX_DB_API_URL=http://145.190.8.19:3010
PLC_COMMAND_POLL_INTERVAL_SEC=5
PLC_COMMAND_LEASE_SEC=60
# true = no escribe al PLC real; solo valida flujo Linux -> Windows -> Linux
PLC_DRY_RUN=true
PLC_DEVICE_ID_SERIAL=151.24.7.13
PLC_DEVICE_IP=192.168.1.100
PLC_DEVICE_PORT=502
PLC_DEVICE_UNIT_ID=1
PLC_DEVICE_TIMEOUT_SEC=5

# --- DB tuning (consumido por APIs) ---
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONN_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=10000
DB_SLOW_LOG_MS=500

# --- Logging / CORS ---
LOG_LEVEL=info
CORS_ORIGIN=*

# --- Auth (shared main-api + auth-api) ---
# Genera con: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_AL_MENOS_32_CARACTERES
INTERNAL_API_KEY=CHANGE_ME_RANDOM_32_CHARS

# --- Redis (cache + rate-limit distribuido) ---
# REDIS_PASSWORD: generar con `openssl rand -hex 32`
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
REDIS_KEY_PREFIX=emeltec:

# --- DGA (Dirección General de Aguas) ---
# Generar UNA sola vez con: openssl rand -hex 32 (cambiarla rompe descifrado)
DGA_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS
DGA_API_URL=https://apimee.mop.gob.cl/api/v1/mediciones/subterraneas
DGA_RUT_EMPRESA=12345678-9

# --- DGA → GCS exporter (solicitado por CCU_Central, genérico) ---
# Sube a Google Cloud Storage (Parquet) cada envío DGA con RESPUESTA de SNIA
# (enviado o rechazado). Selección por-sitio: pozo_config.dga_gcs_export=TRUE.
ENABLE_DGA_GCS_WORKER=false
DGA_GCS_BUCKET=raw-reg-ind-tc-ext-emeltec-prod
DGA_GCS_BATCH_MINUTES=60
# Service account JSON de GCS. Si se omite, usa GOOGLE_APPLICATION_CREDENTIALS.
DGA_GCS_KEY_FILE=/ruta/al/service-account.json
DGA_GCS_PROVEEDOR=EMELTEC
# DGA_GCS_MAX_PER_CYCLE=500

# --- Email (Resend) ---
RESEND_API_KEY=re_TU_API_KEY_AQUI
RESEND_FROM=Emeltec - Panel Industrial <noreply@emeltec.cl>
FRONTEND_URL=https://cloud.emeltec.cl/login

# --- Rate limit global ---
# 0 = deshabilitado
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX=5000

# --- Workers (en cluster, encender sólo en 1 réplica) ---
ENABLE_ALERTS_WORKER=true
ENABLE_DGA_WORKER=true
ENABLE_INGESTION_WORKER=true
ENABLE_SUBMISSION_WORKER=false
ENABLE_HEALTH_DIGEST_WORKER=false
ENABLE_MATHEI_SIMULATION_WORKER=false

# --- Worker tuning ---
ALERT_POLL_MS=60000
ALERT_TIMEZONE=America/Santiago
DGA_WORKER_POLL_MS=60000
DGA_WORKER_CATCHUP=false
INGESTION_CRON=* * * * *
SUBMISSION_CRON=*/5 * * * *
HEALTH_DIGEST_POLL_MS=60000
MONITOR_PRIMARY_EMAIL=druiz@emeltec.cl

# --- Simulacion Mathei -> Electrico/RILES (pruebas, apagado por defecto) ---
MATHEI_SIM_DRY_RUN=true
MATHEI_SIM_AUTO_CONFIGURE=false
MATHEI_SIM_SOURCE_SERIAL=151.23.33.22
MATHEI_SIM_ELECTRIC_SITE_ID=
MATHEI_SIM_RILES_SITE_ID=
MATHEI_SIM_ELECTRIC_SERIAL=MATHEI-ELECTRIC-SIM
MATHEI_SIM_RILES_SERIAL=MATHEI-RILES-SIM
MATHEI_SIM_POLL_MS=30000
MATHEI_SIM_LOOKBACK_MINUTES=180
MATHEI_SIM_ROW_LIMIT=1000
MATHEI_SIM_RILES_MIN_L=1

# --- Azure Blob (documentos bitácora) — OPCIONAL ---
# Sin esto, /api/documentos responde 503
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=bitacoradocumentos
AZURE_STORAGE_SAS_TTL_MIN=15
DOCUMENTOS_MAX_MB=25
