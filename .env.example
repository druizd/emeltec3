# Variables globales del stack docker compose en raíz.
# Copia este archivo como .env y completa con valores reales.
# NUNCA versionar el .env real.

# --- Base de datos TimescaleDB (compartida entre servicios) ---
POSTGRES_DB=db_infra
POSTGRES_USER=admin_infra
POSTGRES_PASSWORD=TU_PASSWORD_AQUI

# --- Puertos expuestos en el host ---
POSTGRES_HOST_PORT=5433
MAIN_API_HOST_PORT=3000
AUTH_API_HOST_PORT=3001
FRONTEND_HOST_PORT=5173
METRICS_HOST_PORT=8081
CSVCONSUMER_HOST_PORT=50051
