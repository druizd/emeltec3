# Copia este archivo como .env si ejecutas auth-api fuera de Docker Compose.
# JWT_SECRET e INTERNAL_API_KEY deben coincidir con main-api/.env.
NODE_ENV=production
PORT=3001
JWT_SECRET=CHANGE_ME
MAIN_API_URL=http://main-api:3000
INTERNAL_API_KEY=CHANGE_ME
DB_HOST=timescaledb
DB_PORT=5432
DB_NAME=telemetry_platform
DB_USER=postgres
DB_PASSWORD=CHANGE_ME
