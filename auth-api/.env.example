# Copia este archivo como .env si ejecutas auth-api fuera de Docker Compose.
# JWT_SECRET e INTERNAL_API_KEY deben coincidir con main-api/.env.
# Generar valores fuertes: openssl rand -hex 32
# NUNCA dejar los placeholders en producción.
NODE_ENV=production
PORT=3001
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
MAIN_API_URL=http://localhost:3000
INTERNAL_API_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
DB_HOST=localhost
DB_PORT=5433
DB_NAME=db_infra
DB_USER=admin_infra
DB_PASSWORD=TU_PASSWORD_AQUI
